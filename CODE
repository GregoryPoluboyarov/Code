        if (!empty($new_email) && filter_var($new_email, FILTER_VALIDATE_EMAIL)) {
            $_SESSION['email'] = $new_email;
            $success = $current_language === 'ru' ? 'Email успешно обновлен!' : 'Email updated successfully!';
        }
        
        if (!empty($new_bio)) {
            $_SESSION['bio'] = $new_bio;
            $success = $current_language === 'ru' ? 'Информация обновлена!' : 'Information updated!';
        }
    }
    
    // Обработка смены пароля
    if (isset($_POST['change_password'])) {
        $old_password = $_POST['old_password'] ?? '';
        $new_password = $_POST['new_password'] ?? '';
        $confirm_password = $_POST['confirm_password'] ?? '';
        
        if (empty($old_password) || empty($new_password) || empty($confirm_password)) {
            $error = $current_language === 'ru' ? 'Заполните все поля пароля!' : 'Fill in all password fields!';
        } elseif (strlen($new_password) < 6) {
            $error = $current_language === 'ru' ? 'Новый пароль должен быть минимум 6 символов' : 'New password must be at least 6 characters';
        } elseif ($new_password !== $confirm_password) {
            $error = $current_language === 'ru' ? 'Новые пароли не совпадают' : 'New passwords do not match';
        } else {
            $success = $current_language === 'ru' ? 'Пароль успешно изменен!' : 'Password changed successfully!';
        }
    }
    
    // Обработка загрузки аватара
    if (isset($_FILES['avatar']) && $_FILES['avatar']['error'] === 0) {
        $allowed = ['jpg', 'jpeg', 'png', 'gif', 'webp'];
        $filename = $_FILES['avatar']['name'];
        $ext = strtolower(pathinfo($filename, PATHINFO_EXTENSION));
        
        if (in_array($ext, $allowed)) {
            $new_filename = 'avatar_' . md5($username) . '.' . $ext;
            $upload_path = 'uploads/avatars/' . $new_filename;
            
            if (!is_dir('uploads/avatars')) {
                mkdir('uploads/avatars', 0777, true);
            }
            
            if (move_uploaded_file($_FILES['avatar']['tmp_name'], $upload_path)) {
                $_SESSION['avatar'] = $upload_path;
                $success = $current_language === 'ru' ? 'Аватар успешно обновлен!' : 'Avatar updated successfully!';
            } else {
                $error = $current_language === 'ru' ? 'Ошибка загрузки аватара' : 'Avatar upload error';
            }
        } else {
            $error = $current_language === 'ru' ? 'Разрешены только: JPG, PNG, GIF, WEBP' : 'Only allowed: JPG, PNG, GIF, WEBP';
        }
    }
}

