                    canvasConfetti({ particleCount: 30, spread: 40, origin: { y: 0.8 }, colors: ['#00f4ff', '#c084fc'] });
                } else {
                    btn.classList.remove('faved');
                    btn.innerHTML = '<i class="fas fa-star"></i> В ИЗБРАННОЕ';
                }
                localStorage.setItem('buildFavsPro', JSON.stringify(favsPro));
                updateStatsPro();
            });
        });
        
        updateStatsPro();
    }

    window.copyBuildProHandler = function(text) {
        navigator.clipboard.writeText(text).then(() => {
            canvasConfetti({ particleCount: 100, spread: 70, origin: { y: 0.7 }, colors: ['#00f4ff', '#c084fc', '#ffd700'] });
            alert('✅ Сборка скопирована в буфер обмена!');
        }).catch(() => {
            alert('❌ Не удалось скопировать');
        });
    };

    function initBuildFiltersPro() {
        const filterBtns = document.querySelectorAll('.build-filter-btn');
        const buildCards = document.querySelectorAll('.build-pro-card');
        
        filterBtns.forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                filterBtns.forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                const role = this.dataset.role;
                
                buildCards.forEach(card => {
                    if (role === 'all' || card.dataset.role === role) {
                        card.style.display = '';
                        card.style.animation = 'fadeInUp 0.5s ease forwards';
                    } else {
                        card.style.display = 'none';
                    }
                });
            });
        });
    }

    function initItemTooltipsPro() {
        let tooltip = null;
        document.addEventListener('mouseover', (e) => {
            const img = e.target.closest('.items-grid-pro img');
            if (img && img.src) {
                if (!tooltip) {
                    tooltip = document.createElement('div');
                    tooltip.className = 'item-tooltip-pro';
                    document.body.appendChild(tooltip);
                }
                const itemName = img.getAttribute('data-item-name') || img.title;
                tooltip.textContent = itemName;
                tooltip.style.left = (e.pageX + 15) + 'px';
                tooltip.style.top = (e.pageY - 30) + 'px';
                tooltip.style.display = 'block';
            } else if (tooltip) {
                tooltip.style.display = 'none';
            }
        });
        document.addEventListener('mousemove', (e) => {
            if (tooltip && tooltip.style.display === 'block') {
                tooltip.style.left = (e.pageX + 15) + 'px';
                tooltip.style.top = (e.pageY - 30) + 'px';
            }
        });
    }

    if (document.getElementById('buildsGrid')) {
        renderBuildsPro();
        setTimeout(() => {
            initBuildFiltersPro();
            initItemTooltipsPro();
        }, 100);
