window.copyBuildProHandler = function(text) {
    navigator.clipboard.writeText(text).then(() => {
        canvasConfetti({ particleCount: 100, spread: 70, origin: { y: 0.7 }, colors: ['#00f4ff', '#c084fc', '#ffd700'] });
        alert('✅ Сборка скопирована в буфер обмена!\n\n' + text.substring(0, 80) + '...');
    }).catch(() => {
        // fallback для старых браузеров
        const textarea = document.createElement('textarea');
        textarea.value = text;
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand('copy');
        document.body.removeChild(textarea);
        alert('✅ Сборка скопирована в буфер обмена!');
        canvasConfetti({ particleCount: 50, spread: 50, origin: { y: 0.7 }, colors: ['#00f4ff', '#c084fc'] });
