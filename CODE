            if (currentSort === 'name') return a.name.localeCompare(b.name);
            if (currentSort === 'complexity') return a.complexity - b.complexity;
            if (currentSort === 'attr') { const order = { str: 1, agi: 2, int: 3, all: 4 }; return (order[a.primaryAttr] || 5) - (order[b.primaryAttr] || 5); }
            return 0;
        });
        return filtered;
