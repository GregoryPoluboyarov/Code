                id: hero.id,
                name: hero.localized_name,
                rawName: hero.name.replace('npc_dota_hero_', ''),
                primaryAttr: hero.primary_attr,
                complexity: hero.complexity || 1,
                attackType: hero.attack_type || 'Melee',
