            origin: { y: 0.6 },
            colors: ['#00f4ff', '#c084fc', '#ff2a6d', '#ffd700']
        });
    }, 500);

    // Дополнительный эффект при клике на аватар
    document.querySelector('.avatar')?.addEventListener('click', () => {
        canvasConfetti({
            particleCount: 150,
            spread: 100,
            origin: { y: 0.5 },
            colors: ['#00f4ff', '#ffd700', '#c084fc', '#ff2a6d']
        });
    });
    
    // Загрузка аватара для профиля
    function loadProfileAvatar() {
        fetch('get_avatar.php')
            .then(res => res.json())
            .then(data => {
                if (data.avatar) {
                    const img = document.querySelector('#profileAvatar img');
                    const letter = document.querySelector('#profileAvatarLetter');
                    if (img && letter) {
                        img.src = data.avatar + '?t=' + Date.now();
                        img.style.display = 'block';
                        letter.style.display = 'none';
                    }
                }
            })
            .catch(err => console.log('Ошибка загрузки аватара:', err));
    }

    // Загружаем аватар после загрузки страницы
    document.addEventListener('DOMContentLoaded', loadProfileAvatar);
    
    // Плавная анимация появления элементов
    const observerOptions = {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
    };
    
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.style.opacity = '1';
                entry.target.style.transform = 'translateY(0)';
                observer.unobserve(entry.target);
            }
        });
    }, observerOptions);
    
    document.querySelectorAll('.stat-item, .detail-card, .progress-card').forEach(el => {
        el.style.opacity = '0';
        el.style.transform = 'translateY(30px)';
        el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
        observer.observe(el);
    });
    
    // Эффект частиц при наведении на MMR
    const mmrElement = document.querySelector('.stat-item:first-child');
    if (mmrElement) {
        mmrElement.addEventListener('mouseenter', () => {
            canvasConfetti({
                particleCount: 30,
                spread: 40,
                origin: { y: 0.7 },
                colors: ['#00f4ff', '#ffffff']
            });
        });
    }
    
    // Счётчик лайков
    let likeCount = 0;
    const likeButtons = document.querySelectorAll('.btn-action');
    likeButtons.forEach(btn => {
        btn.addEventListener('click', (e) => {
            if (btn.classList.contains('btn-logout')) return;
            likeCount++;
            if (likeCount % 5 === 0) {
                canvasConfetti({
                    particleCount: 80,
                    spread: 60,
                    origin: { y: 0.7 },
                    colors: ['#ffd700', '#00f4ff']
                });
            }
        });
    });
    
    // Эффект печатной машинки для никнейма
    const nameElement = document.querySelector('.profile-name');
    if (nameElement && !nameElement.hasAttribute('data-animated')) {
        nameElement.setAttribute('data-animated', 'true');
        const originalText = nameElement.innerText;
        nameElement.innerText = '';
        let i = 0;
        const typingInterval = setInterval(() => {
            if (i < originalText.length) {
                nameElement.innerText += originalText.charAt(i);
                i++;
            } else {
                clearInterval(typingInterval);
            }
        }, 50);
    }
</script>

