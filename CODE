                baseStr: Math.floor(Math.random() * 20) + 15,
                baseInt: Math.floor(Math.random() * 20) + 15,
                baseArmor: (Math.random() * 5 + 1).toFixed(1),
                moveSpeed: Math.floor(Math.random() * 30) + 280,
