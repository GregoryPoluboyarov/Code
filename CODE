            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                const id = parseInt(btn.dataset.id);
                if (!likesPro[id]) likesPro[id] = 0;
                likesPro[id]++;
                btn.classList.add('liked');
                btn.querySelector('.like-count').textContent = likesPro[id];
                localStorage.setItem('buildLikesPro', JSON.stringify(likesPro));
                updateStatsPro();
                canvasConfetti({ particleCount: 40, spread: 50, origin: { y: 0.8 }, colors: ['#ff2a6d', '#ff6b6b'] });
            });
        });
        
        document.querySelectorAll('.fav-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                const id = parseInt(btn.dataset.id);
                favsPro[id] = !favsPro[id];
